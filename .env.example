# =======================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and update with your actual values
# NEVER commit .env files to version control!
# =======================================================================

# Mollie Payment Integration
MOLLIE_API_KEY=live_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
MOLLIE_WEBHOOK_SECRET=your_webhook_secret_here

# Local only: skip Mollie and redirect straight to payment-success after checkout.
# Requires APP_ENV/development host (localhost, 127.0.0.1, or dev ports 8000/8888).
# Remove or set to 0 before production. Optional: leave MOLLIE_API_KEY empty when this is 1.
# 1/true + localhost (or APP_ENV=development): skips Mollie for all flows including pay-on-arrival deposit
MOCK_MOLLIE_PAYMENTS=false

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# JWT Configuration (generate with: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here_generate_with_openssl_rand_base64_64

# Flask Application Secret Key (generate with: openssl rand -base64 32)
FLASK_SECRET_KEY=your_flask_secret_key_here

# API Security
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_HOUR=1000

# Database Configuration (if using database in future)
DB_HOST=localhost
DB_NAME=nijenhuis_bookings
DB_USER=nijenhuis_user
DB_PASSWORD=your_secure_database_password

# Optional: absolute path for operational JSON (default: <project>/data)
# DATA_DIR=/var/lib/nijenhuis-data

# Application Configuration
# Set to 'production' for production deployments
APP_ENV=development
# Debug mode: only enabled in development (set to 'true' for development)
APP_DEBUG=true
APP_URL=https://nijenhuis-botenverhuur.com

# Proxy Configuration
# Set to 'true' when running behind nginx reverse proxy (production)
TRUST_PROXY=false

# Email Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
NOTIFICATION_EMAIL=info@nijenhuis-botenverhuur.nl

# Microsoft Graph Email (OAuth 2.0)
MS_GRAPH_TENANT_ID=your_tenant_id_here
MS_GRAPH_CLIENT_ID=your_client_id_here
MS_GRAPH_CLIENT_SECRET=your_client_secret_here
MS_GRAPH_MAILBOX=no-reply@nijenhuis-botenverhuur.com

# Security Configuration
SESSION_TIMEOUT_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
IP_BLOCK_DURATION_MINUTES=15

# File Upload Limits (if implemented)
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/nijenhuis/app.log

# Chatbot API Key (legacy)
CHATBOT_API_KEY=your_chatbot_api_key_here

# Booking System API Key (for chatbot integration)
BOOKING_API_KEY=your_booking_api_key_here

# Inventory System API Key (for chatbot integration)
INVENTORY_API_KEY=your_inventory_api_key_here

# Employee Authentication
EMPLOYEE_USERNAME=medewerker
EMPLOYEE_PASSWORD=your_secure_employee_password_here

# Blog Portal Authentication (separate from admin/employee)
# Generate hash with: php -r "echo password_hash('your-password', PASSWORD_ARGON2ID);"
BLOG_USERNAME=blog-author
BLOG_PASSWORD_HASH=your_argon2_or_bcrypt_hash_here

# Google Places API (for fetching reviews into schema.org AggregateRating)
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" or "Places API" in the Google Cloud Console.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJu3zxOZVxyEcRUGE17f1ZhIk
