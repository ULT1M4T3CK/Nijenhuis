# ================================================
# Nijenhuis Botenverhuur - .gitignore
# Production Security Configuration
# ================================================

# ===================
# Environment & Secrets
# ===================
.env
.env.*
.env.backup.*
!.env.example
config/api_keys.json

# ===================
# Dependencies
# ===================
node_modules/
venv/
__pycache__/
*.pyc

# ===================
# Logs & Temporary Files
# ===================
logs/
*.log
*.log.*
cookies.txt

# ===================
# Session & Auth Data
# ===================
admin/admin_sessions.json
data/bookings.json
data/bookings_archive.json
data/for-sale.json
data/articles.json
data/blog-styles.json
data/blog-redirects.json
data/backups/

# ===================
# IDE & Editor
# ===================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ===================
# Build Artifacts
# ===================
dist/
build/
*.min.js
*.min.css

# ===================
# OS Files
# ===================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===================
# Test & Debug Files
# ===================
check_availability_test.php
widget_debug.js
admin/test-*.php
admin/debug_*.php

# ===================
# Backup Files
# ===================
*.bak
*.backup
*.orig
