# ============================================
# Nijenhuis Botenverhuur - Apache Configuration
# Performance & Caching Optimization
# ============================================

# Enable Gzip Compression - Compress HTML, CSS, JS, JSON, XML, SVG and fonts
<IfModule mod_deflate.c>
    # HTML compression (primary focus)
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE application/xhtml+xml
    
    # CSS and JavaScript
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    
    # XML and SVG
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    
    # Fonts
    AddOutputFilterByType DEFLATE application/x-font-ttf
    AddOutputFilterByType DEFLATE application/x-font-opentype
    AddOutputFilterByType DEFLATE font/opentype
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
    
    # Set compression level (1-9, 6 is a good balance)
    DeflateCompressionLevel 6
    
    # Don't compress already compressed files
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|zip|gz|bz2|rar)$ no-gzip dont-vary
    SetEnvIfNoCase Request_URI \.(?:exe|t?gz|zip|bz2|sit|rar)$ no-gzip dont-vary
</IfModule>

# Browser Caching - Leverage Browser Cache
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Default: 1 week
    ExpiresDefault "access plus 1 week"
    
    # Images: 1 month
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    
    # CSS/JS: 1 week (with versioning)
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType text/javascript "access plus 1 week"
    
    # Fonts: 1 month
    ExpiresByType font/woff2 "access plus 1 month"
    ExpiresByType font/woff "access plus 1 month"
    ExpiresByType application/font-woff "access plus 1 month"
    ExpiresByType application/font-woff2 "access plus 1 month"
    
    # HTML/PHP: No cache (dynamic content) - always get fresh content
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType application/xhtml+xml "access plus 0 seconds"
    ExpiresByType application/x-httpd-php "access plus 0 seconds"
</IfModule>

# Cache-Control Headers
<IfModule mod_headers.c>
    # Images - Long cache
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    
    # CSS/JS - Short cache with must-revalidate (reduced from 1 week to 1 hour for faster updates)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
    
    # HTML/PHP - No cache to ensure fresh content
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # Service Worker - Never cache (must always be fresh)
    <FilesMatch "sw\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # Fonts - Long cache
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    
    # Security Headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Blog portal on localhost only: allow IDE / simple-browser embedding (avoids chrome-error subframe issues)
    <If "%{REQUEST_URI} =~ m#^/blog-portal# && %{HTTP_HOST} =~ m#^(localhost|127\\.0\\.0\\.1)(:[0-9]+)?$#">
        Header unset X-Frame-Options
        Header set Content-Security-Policy "frame-ancestors *"
    </If>
</IfModule>

# ETags - Disable for better caching performance
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(env|env\.bak|env\.backup|env\.old|env\.tmp|env~|json|log|md|sql|bak|backup|old|tmp|swp|~)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Explicitly block .env files (including hidden files)
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Rewrite rules for clean URLs (optional)
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect index.php to root
    RewriteRule ^pages/index\.php$ / [R=301,L]
</IfModule>
