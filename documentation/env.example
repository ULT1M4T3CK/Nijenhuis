# =======================================================================
# ENVIRONMENT CONFIGURATION EXAMPLE
# Copy this file to .env and update with your actual values
# NEVER commit .env files to version control!
# =======================================================================

# Mollie Payment Integration
MOLLIE_API_KEY=test_your_mollie_test_key_here
# SECURITY: Webhook secret is REQUIRED in production for signature verification
MOLLIE_WEBHOOK_SECRET=your_webhook_secret_here

# Microsoft Graph Email (OAuth 2.0)
MS_GRAPH_TENANT_ID=your_tenant_id_here
MS_GRAPH_CLIENT_ID=your_client_id_here
MS_GRAPH_CLIENT_SECRET=your_client_secret_here
MS_GRAPH_MAILBOX=no-reply@nijenhuis-botenverhuur.com

# Chatbot API Configuration
# Note: VITE_ prefixed variables are exposed to client-side code
# Use with caution - these will be visible in the browser bundle
VITE_CHATBOT_API_KEY=your_chatbot_api_key_here
VITE_CHATBOT_API_ENDPOINT=http://localhost:5001/api/chat
VITE_CHATBOT_HEALTH_ENDPOINT=http://localhost:5001/api/health

# Chatbot API Security (for server-side API)
# Comma-separated list of allowed origins for chatbot API access
CHATBOT_ALLOWED_ORIGINS=https://your-chatbot-domain.com,https://api.your-chatbot-provider.com
BOOKING_API_KEY=your_booking_api_key_here
INVENTORY_API_KEY=your_inventory_api_key_here

# Admin Authentication
# SECURITY: Use password hashes only (plain text passwords are no longer supported)
# Generate hashes using: php scripts/migrate-passwords.php
ADMIN_USERNAME=your_secure_admin_username
ADMIN_PASSWORD_HASH=$2y$10$example_hash_here_generate_using_migration_script
# OLD (REMOVE THIS): ADMIN_PASSWORD=your_very_secure_password_here

# Employee Authentication (optional)
EMPLOYEE_USERNAME=your_employee_username
EMPLOYEE_PASSWORD_HASH=$2y$10$example_hash_here_generate_using_migration_script
# OLD (REMOVE THIS): EMPLOYEE_PASSWORD=your_employee_password

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_at_least_64_characters_long_random_string

# Flask Application Secret Key
FLASK_SECRET_KEY=your_flask_secret_key_here_minimum_32_characters

# API Security
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_HOUR=1000

# Database Configuration (if using database in future)
DB_HOST=localhost
DB_NAME=nijenhuis_bookings
DB_USER=nijenhuis_user
DB_PASSWORD=secure_database_password

# Application Configuration
# Set to 'production' for production deployments
APP_ENV=production
# Debug mode: only enabled in development (set to 'true' for development)
APP_DEBUG=false
APP_URL=https://nijenhuis-botenverhuur.com

# Proxy Configuration
# Set to 'true' when running behind nginx reverse proxy (production)
# This enables Flask to trust X-Forwarded-* headers for HTTPS detection
TRUST_PROXY=true

# Flask Secret Key (generate a secure random key for production)
FLASK_SECRET_KEY=your-super-secure-flask-secret-key-change-in-production

# Email Configuration
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
NOTIFICATION_EMAIL=info@nijenhuis-botenverhuur.nl

# Security Configuration
SESSION_TIMEOUT_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
IP_BLOCK_DURATION_MINUTES=15

# File Upload Limits (if implemented)
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/nijenhuis/app.log

